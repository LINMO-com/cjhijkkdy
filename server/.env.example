# ============================================================================
# 后端环境变量配置示例
# 使用前复制为 .env 并填写真实值，.env 文件切勿提交到版本库
# ============================================================================

# 服务端口
PORT=3000

# MySQL 数据库连接
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=doc_share

# JWT 鉴权密钥（管理员登录令牌签名用，请使用随机长字符串）
JWT_SECRET=please_change_this_to_a_random_long_string_at_least_32_chars

# JWT 令牌有效期（如 8h / 7d）
JWT_EXPIRES_IN=8h

# 分享链接 HMAC 签名密钥（核心安全项，务必使用高强度随机字符串）
# 该密钥仅存后端，前端无法伪造分享令牌
SHARE_SECRET=please_change_this_to_another_random_long_string_at_least_64_chars

# 普通文件分享链接有效期（分钟）
SHARE_TTL_NORMAL_MINUTES=15

# 大文件分享链接有效期（分钟）
SHARE_TTL_LARGE_MINUTES=30

# 大文件阈值（字节），>= 该值视为大文件。默认 100MB
LARGE_FILE_THRESHOLD_BYTES=104857600

# 文件存储根目录（本地存储）
STORAGE_ROOT=./storage

# 允许上传的文件扩展名白名单（逗号分隔，小写）
ALLOWED_EXTENSIONS=pdf,doc,docx,xls,xlsx,ppt,pptx,txt,md,json,csv,jpg,jpeg,png,gif,webp,svg,zip,rar

# 单文件最大上传大小（字节），默认 500MB
MAX_UPLOAD_SIZE=524288000

# 跨域允许的前端来源（逗号分隔）
CORS_ORIGIN=http://localhost:5173
